async function markBillPaid(id){
  const b = state.contas.find(x=>x.id===id);
  if(!b) return;
  try{
    await userDoc('transacoes').add({
      tipo:'despesa', valor:Number(b.valor), categoria:b.categoria, carteira:b.carteira,
      data: todayISO(), descricao:`Pagamento: ${b.nome}`, recorrente:false, createdAt: Date.now()
    });
    if(b.recorrente){
      const next = new Date(b.vencimento+'T00:00');
      next.setMonth(next.getMonth()+1);
      await userDoc('contas').doc(id).update({ paga:false, vencimento: next.toISOString().slice(0,10) });
    } else {
      await userDoc('contas').doc(id).update({ paga:true });
    }
    toast('Conta paga! 🎉');
  }catch(e){ console.error(e); toast('Erro ao marcar como paga'); }
}
function processRecurringBills(){
  // garante que contas recorrentes pagas com vencimento já no passado voltem a ficar pendentes
  state.contas.forEach(b=>{
    if(b.recorrente && b.paga && daysBetween(b.vencimento, todayISO())>=0){
      userDoc('contas').doc(b.id).update({ paga:false }).catch(()=>{});
    }
  });
}

