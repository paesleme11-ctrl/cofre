<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover">
<title>Cofre — Finanças</title>
<link rel="icon" href="data:,">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..900&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.4/chart.umd.min.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>
<style>
/* ===================== DESIGN TOKENS ===================== */
:root{
  --bg:#14110d;
  --bg-elev:#1c170f;
  --bg-card:#221c13;
  --bg-card2:#2a2316;
  --border:rgba(255,255,255,.08);
  --border-soft:rgba(255,255,255,.05);
  --text:#f3ecdf;
  --text-dim:#a99d87;
  --text-faint:#766c5c;
  --accent:#e3b13e;
  --accent-ink:#1a1408;
  --accent-dim:rgba(227,177,62,.14);
  --income:#8bbf6f;
  --income-dim:rgba(139,191,111,.14);
  --expense:#df7849;
  --expense-dim:rgba(223,120,73,.14);
  --danger:#e2584f;
  --danger-dim:rgba(226,88,79,.14);
  --radius-lg:22px;
  --radius-md:16px;
  --radius-sm:10px;
  --shadow:0 8px 30px rgba(0,0,0,.35);
  --safe-bottom:env(safe-area-inset-bottom,0px);
  --safe-top:env(safe-area-inset-top,0px);
}
html[data-theme="light"]{
  --bg:#faf6ee;
  --bg-elev:#ffffff;
  --bg-card:#ffffff;
  --bg-card2:#f3ecdc;
  --border:rgba(20,15,5,.09);
  --border-soft:rgba(20,15,5,.05);
  --text:#241d12;
  --text-dim:#7a6f5b;
  --text-faint:#a89c85;
  --accent:#c8901f;
  --accent-ink:#fff8e8;
  --accent-dim:rgba(200,144,31,.12);
  --income:#4f8f3a;
  --income-dim:rgba(79,143,58,.1);
  --expense:#c85a2e;
  --expense-dim:rgba(200,90,46,.1);
  --danger:#c43d35;
  --danger-dim:rgba(196,61,53,.1);
  --shadow:0 8px 24px rgba(60,40,10,.12);
}
*{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
html,body{margin:0;padding:0;height:100%;}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Work Sans',sans-serif;
  overscroll-behavior-y:none;
  -webkit-font-smoothing:antialiased;
  transition:background .25s ease,color .25s ease;
}
.num{font-family:'Fraunces',serif; font-feature-settings:"tnum";}
button{font-family:inherit; border:none; background:none; cursor:pointer; color:inherit;}
input,select,textarea{font-family:inherit; color:var(--text); background:transparent;}
::-webkit-scrollbar{display:none;}
a{color:inherit;}

/* ===================== APP SHELL ===================== */
#splash{
  position:fixed; inset:0; background:var(--bg); display:flex; flex-direction:column;
  align-items:center; justify-content:center; gap:14px; z-index:999;
}
#splash .mark{
  font-family:'Fraunces',serif; font-weight:600; font-size:34px; letter-spacing:.5px;
  display:flex; align-items:center; gap:10px;
}
#splash .coin{width:14px;height:14px;border-radius:50%;background:var(--accent); box-shadow:0 0 22px var(--accent); animation:pulse 1.4s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:.4; transform:scale(.85);} 50%{opacity:1; transform:scale(1);}}
#splash small{color:var(--text-faint); letter-spacing:1.5px; text-transform:uppercase; font-size:11px;}

#app{display:none; max-width:560px; margin:0 auto; min-height:100vh; position:relative; padding-bottom:calc(92px + var(--safe-bottom));}

header.topbar{
  position:sticky; top:0; z-index:40; background:var(--bg); padding:calc(18px + var(--safe-top)) 20px 14px;
  display:flex; align-items:center; justify-content:space-between;
}
header.topbar .brand{display:flex; align-items:center; gap:9px;}
header.topbar .brand .coin{width:9px;height:9px;border-radius:50%;background:var(--accent);}
header.topbar h1{font-family:'Fraunces',serif; font-size:21px; font-weight:600; margin:0; letter-spacing:.2px;}
header.topbar .icon-btn{
  width:38px; height:38px; border-radius:50%; display:flex; align-items:center; justify-content:center;
  background:var(--bg-card); border:1px solid var(--border); color:var(--text-dim);
}
header.topbar .icon-btn:active{transform:scale(.93);}

main{padding:4px 20px 20px;}
.view{display:none; animation:fadein .35s ease;}
.view.active{display:block;}
@keyframes fadein{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}

/* ===================== CARDS / COMMON ===================== */
.card{
  background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg);
  padding:18px; position:relative;
}
.section-title{
  font-size:12px; text-transform:uppercase; letter-spacing:1.2px; color:var(--text-faint);
  font-weight:600; margin:26px 2px 10px; display:flex; align-items:center; justify-content:space-between;
}
.section-title .link{font-size:11.5px; color:var(--accent); text-transform:none; letter-spacing:0; font-weight:600;}
.empty-state{
  text-align:center; padding:36px 16px; color:var(--text-faint); font-size:13.5px; line-height:1.6;
}
.empty-state .em{font-size:30px; display:block; margin-bottom:8px;}

/* ===== Saldo hero ===== */
.balance-hero{
  background:linear-gradient(155deg,var(--bg-card2),var(--bg-card) 60%);
  border:1px solid var(--border); border-radius:var(--radius-lg); padding:24px 20px 20px; position:relative; overflow:hidden;
}
.balance-hero::after{
  content:""; position:absolute; right:-40px; top:-40px; width:160px; height:160px; border-radius:50%;
  background:radial-gradient(circle,var(--accent-dim),transparent 70%);
}
.balance-hero .label{font-size:12.5px; color:var(--text-dim); display:flex; align-items:center; gap:6px;}
.balance-hero .amount{font-size:40px; font-weight:600; margin:6px 0 16px; letter-spacing:-.5px; position:relative; z-index:1;}
.balance-hero .amount.hidden-val{filter:blur(7px); user-select:none;}
.balance-hero .row{display:flex; gap:10px;}
.stat-chip{
  flex:1; background:var(--bg-elev); border:1px solid var(--border-soft); border-radius:var(--radius-sm);
  padding:10px 12px;
}
.stat-chip .l{font-size:11px; color:var(--text-faint); display:flex; align-items:center; gap:5px; margin-bottom:3px;}
.stat-chip .v{font-size:16px; font-weight:600;}
.dot{width:7px;height:7px;border-radius:50%; flex-shrink:0;}
.dot.in{background:var(--income);} .dot.out{background:var(--expense);}

/* ===== wallets scroller ===== */
.wallets-scroll{display:flex; gap:10px; overflow-x:auto; margin:0 -20px; padding:0 20px 4px; scroll-snap-type:x proximate;}
.wallet-card{
  flex:0 0 auto; min-width:138px; background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-md);
  padding:13px 14px; scroll-snap-align:start;
}
.wallet-card .name{font-size:12px; color:var(--text-dim); margin-bottom:8px; display:flex; align-items:center; gap:6px;}
.wallet-card .val{font-size:17px; font-weight:600;}
.wallet-card.add{display:flex; align-items:center; justify-content:center; color:var(--text-faint); min-width:64px; border-style:dashed;}

/* ===== charts ===== */
.chart-card{padding:16px 14px 8px;}
.chart-card .legend{display:flex; flex-wrap:wrap; gap:8px 14px; margin-top:10px; justify-content:center;}
.legend-item{display:flex; align-items:center; gap:6px; font-size:12px; color:var(--text-dim);}
.legend-item .sw{width:9px;height:9px;border-radius:3px;}
canvas{max-width:100%;}

/* ===== alerts list (contas a vencer) ===== */
.alert-row{
  display:flex; align-items:center; gap:12px; padding:12px 0; border-bottom:1px solid var(--border-soft);
}
.alert-row:last-child{border-bottom:none;}
.alert-row .ic{width:38px;height:38px;border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:17px; flex-shrink:0;}
.alert-row .info{flex:1; min-width:0;}
.alert-row .info .t{font-size:14px; font-weight:600;}
.alert-row .info .s{font-size:12px; color:var(--text-faint); margin-top:1px;}
.alert-row .amt{font-size:14px; font-weight:600; white-space:nowrap;}
.badge{font-size:10.5px; padding:3px 8px; border-radius:20px; font-weight:600; white-space:nowrap;}
.badge.late{background:var(--danger-dim); color:var(--danger);}
.badge.soon{background:var(--accent-dim); color:var(--accent);}
.badge.ok{background:var(--income-dim); color:var(--income);}

/* ===== metas mini ===== */
.goal-mini{margin-bottom:14px;}
.goal-mini:last-child{margin-bottom:0;}
.goal-mini .top{display:flex; justify-content:space-between; font-size:13px; margin-bottom:6px;}
.goal-mini .top .nm{font-weight:600;}
.goal-mini .top .pc{color:var(--text-dim); font-size:12px;}
.progress-track{height:7px; background:var(--bg-elev); border-radius:10px; overflow:hidden;}
.progress-fill{height:100%; border-radius:10px; transition:width .5s ease;}

/* ===================== EXTRATO ===================== */
.month-switch{display:flex; align-items:center; justify-content:center; gap:16px; margin:6px 0 18px;}
.month-switch button{width:32px;height:32px;border-radius:50%; background:var(--bg-card); border:1px solid var(--border); color:var(--text-dim); display:flex; align-items:center; justify-content:center;}
.month-switch .lbl{font-size:14.5px; font-weight:600; min-width:140px; text-align:center; text-transform:capitalize;}

.filter-row{display:flex; gap:8px; overflow-x:auto; margin:0 -20px 16px; padding:0 20px;}
.chip{
  flex:0 0 auto; padding:7px 13px; border-radius:20px; background:var(--bg-card); border:1px solid var(--border);
  font-size:12.5px; color:var(--text-dim); display:flex; align-items:center; gap:5px; white-space:nowrap;
}
.chip.active{background:var(--accent); color:var(--accent-ink); border-color:var(--accent); font-weight:600;}

.tx-group .tx-date{font-size:11.5px; color:var(--text-faint); text-transform:uppercase; letter-spacing:.8px; margin:18px 2px 8px; font-weight:600;}
.tx-group:first-child .tx-date{margin-top:0;}
.tx-row{
  display:flex; align-items:center; gap:12px; padding:12px 4px; border-bottom:1px solid var(--border-soft);
}
.tx-row:active{background:var(--bg-card);}
.tx-row .ic{width:42px;height:42px;border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0;}
.tx-row .info{flex:1; min-width:0;}
.tx-row .info .t{font-size:14.5px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
.tx-row .info .s{font-size:12px; color:var(--text-faint); margin-top:1px;}
.tx-row .amt{font-size:14.5px; font-weight:600; white-space:nowrap;}
.tx-row .amt.in{color:var(--income);} .tx-row .amt.out{color:var(--text);}

/* ===================== CONTAS (bills) ===================== */
.bill-card{
  display:flex; align-items:center; gap:13px; padding:14px; background:var(--bg-card); border:1px solid var(--border);
  border-radius:var(--radius-md); margin-bottom:10px;
}
.bill-card .ic{width:44px;height:44px;border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:19px; flex-shrink:0;}
.bill-card .info{flex:1; min-width:0;}
.bill-card .info .t{font-size:14.5px; font-weight:600;}
.bill-card .info .s{font-size:12px; color:var(--text-faint); margin-top:2px; display:flex; align-items:center; gap:6px;}
.bill-card .right{display:flex; flex-direction:column; align-items:flex-end; gap:6px;}
.bill-card .amt{font-size:14.5px; font-weight:600;}
.bill-card.paid{opacity:.5;}
.mini-btn{
  font-size:11px; font-weight:700; padding:5px 11px; border-radius:20px; background:var(--accent-dim); color:var(--accent);
}
.mini-btn.done{background:var(--income-dim); color:var(--income);}

/* ===================== METAS ===================== */
.goal-card{background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg); padding:18px; margin-bottom:14px;}
.goal-card .head{display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:14px;}
.goal-card .head .nm{font-size:15px; font-weight:600; display:flex; align-items:center; gap:8px;}
.goal-card .head .tag{font-size:10.5px; color:var(--text-faint); text-transform:uppercase; letter-spacing:.6px; margin-top:3px;}
.goal-card .nums{display:flex; justify-content:space-between; font-size:13px; margin:10px 0 4px;}
.goal-card .nums .cur{font-weight:700; font-size:17px;}
.goal-card .nums .tgt{color:var(--text-faint);}
.goal-card .foot{display:flex; justify-content:space-between; align-items:center; margin-top:10px;}
.goal-card .foot .pc{font-size:12px; color:var(--text-dim);}

/* ===================== BOTTOM NAV ===================== */
nav.bottom{
  position:fixed; left:0; right:0; bottom:0; z-index:50; max-width:560px; margin:0 auto;
  background:var(--bg-elev); border-top:1px solid var(--border);
  display:flex; padding:8px 6px calc(8px + var(--safe-bottom));
}
nav.bottom button{
  flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; padding:6px 0; color:var(--text-faint);
  font-size:10.5px; font-weight:600; letter-spacing:.2px;
}
nav.bottom button svg{width:21px;height:21px;}
nav.bottom button.active{color:var(--accent);}

.fab{
  position:fixed; left:50%; transform:translateX(-50%); bottom:calc(58px + var(--safe-bottom)); z-index:55;
  width:58px; height:58px; border-radius:50%; background:var(--accent); color:var(--accent-ink);
  display:flex; align-items:center; justify-content:center; box-shadow:0 10px 26px rgba(227,177,62,.4);
  border:4px solid var(--bg);
}
.fab:active{transform:translateX(-50%) scale(.92);}
.fab svg{width:24px;height:24px;}

/* ===================== MODALS / SHEETS ===================== */
.overlay{
  position:fixed; inset:0; background:rgba(0,0,0,.55); z-index:100; display:none; align-items:flex-end;
  backdrop-filter:blur(2px);
}
.overlay.show{display:flex;}
.sheet{
  background:var(--bg-elev); width:100%; max-width:560px; margin:0 auto; border-radius:26px 26px 0 0;
  max-height:92vh; overflow-y:auto; padding:10px 20px calc(26px + var(--safe-bottom));
  animation:sheetup .3s cubic-bezier(.2,.9,.3,1);
}
@keyframes sheetup{from{transform:translateY(100%);} to{transform:translateY(0);}}
.sheet .handle{width:36px; height:4px; background:var(--border); border-radius:4px; margin:0 auto 16px;}
.sheet .sheet-title{font-family:'Fraunces',serif; font-size:20px; font-weight:600; margin-bottom:18px; display:flex; justify-content:space-between; align-items:center;}
.sheet .sheet-title .x{color:var(--text-faint); width:30px;height:30px;display:flex;align-items:center;justify-content:center; background:var(--bg-card); border-radius:50%;}

.field{margin-bottom:16px;}
.field label{display:block; font-size:12px; color:var(--text-dim); margin-bottom:7px; font-weight:600;}
.field input[type=text],.field input[type=number],.field input[type=date],.field select,.field textarea{
  width:100%; padding:13px 14px; background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-sm);
  font-size:15px;
}
.field textarea{resize:none; min-height:60px;}
.field input:focus,.field select:focus,.field textarea:focus{outline:none; border-color:var(--accent);}

.amount-input{
  display:flex; align-items:center; justify-content:center; gap:6px; padding:18px 0;
}
.amount-input span{font-size:24px; color:var(--text-faint); font-weight:600;}
.amount-input input{
  background:none; border:none; font-family:'Fraunces',serif; font-size:42px; font-weight:600; text-align:center;
  width:220px; color:var(--text);
}
.amount-input input:focus{outline:none;}

.segmented{display:flex; background:var(--bg-card); border-radius:var(--radius-sm); padding:4px; gap:4px; margin-bottom:18px;}
.segmented button{flex:1; padding:10px; border-radius:8px; font-size:13.5px; font-weight:600; color:var(--text-faint);}
.segmented button.active.exp{background:var(--expense-dim); color:var(--expense);}
.segmented button.active.inc{background:var(--income-dim); color:var(--income);}

.chip-grid{display:flex; flex-wrap:wrap; gap:8px;}
.pick-chip{
  padding:9px 13px; border-radius:14px; background:var(--bg-card); border:1.5px solid var(--border); font-size:13px;
  display:flex; align-items:center; gap:6px; color:var(--text-dim);
}
.pick-chip.sel{border-color:var(--accent); background:var(--accent-dim); color:var(--text); font-weight:600;}

.toggle-row{display:flex; align-items:center; justify-content:space-between; padding:4px 0;}
.toggle-row .t{font-size:13.5px; font-weight:600;}
.switch{width:46px; height:27px; background:var(--bg-card); border:1px solid var(--border); border-radius:20px; position:relative; flex-shrink:0;}
.switch::after{content:""; position:absolute; top:2px; left:2px; width:21px; height:21px; border-radius:50%; background:var(--text-faint); transition:all .2s ease;}
.switch.on{background:var(--accent-dim); border-color:var(--accent);}
.switch.on::after{left:21px; background:var(--accent);}

.btn-primary{
  width:100%; padding:15px; border-radius:var(--radius-sm); background:var(--accent); color:var(--accent-ink);
  font-size:15px; font-weight:700; margin-top:6px;
}
.btn-primary:active{opacity:.85;}
.btn-secondary{
  width:100%; padding:14px; border-radius:var(--radius-sm); background:var(--bg-card); color:var(--text-dim);
  font-size:14px; font-weight:600; margin-top:10px; border:1px solid var(--border);
}
.btn-danger-text{width:100%; text-align:center; padding:14px; color:var(--danger); font-size:13.5px; font-weight:600; margin-top:4px;}

.settings-list{display:flex; flex-direction:column; gap:2px;}
.settings-item{
  display:flex; align-items:center; gap:13px; padding:13px 4px; border-bottom:1px solid var(--border-soft);
}
.settings-item .ic{width:36px;height:36px; border-radius:11px; background:var(--bg-card); display:flex; align-items:center; justify-content:center; font-size:15px;}
.settings-item .t{flex:1; font-size:14px; font-weight:600;}
.settings-item .chev{color:var(--text-faint);}

.manage-row{display:flex; align-items:center; gap:10px; padding:10px 0; border-bottom:1px solid var(--border-soft);}
.manage-row .ic{width:34px;height:34px;border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0;}
.manage-row .nm{flex:1; font-size:13.5px; font-weight:600;}
.manage-row .del{color:var(--text-faint); padding:6px;}

.toast{
  position:fixed; bottom:calc(100px + var(--safe-bottom)); left:50%; transform:translateX(-50%) translateY(10px);
  background:var(--bg-card2); border:1px solid var(--border); color:var(--text); padding:11px 18px; border-radius:30px;
  font-size:13px; font-weight:600; z-index:200; opacity:0; transition:all .25s ease; box-shadow:var(--shadow); pointer-events:none;
  display:flex; align-items:center; gap:8px; max-width:80%;
}
.toast.show{opacity:1; transform:translateX(-50%) translateY(0);}

.color-grid{display:flex; flex-wrap:wrap; gap:9px;}
.color-dot{width:30px;height:30px;border-radius:50%; border:2px solid transparent;}
.color-dot.sel{border-color:var(--text);}
.emoji-grid{display:flex; flex-wrap:wrap; gap:8px; max-height:140px; overflow-y:auto;}
.emoji-opt{width:38px;height:38px;border-radius:10px; background:var(--bg-card); display:flex; align-items:center; justify-content:center; font-size:18px; border:1.5px solid transparent;}
.emoji-opt.sel{border-color:var(--accent); background:var(--accent-dim);}

.confirm-box{
  position:fixed; inset:0; z-index:300; display:none; align-items:center; justify-content:center; background:rgba(0,0,0,.6); padding:30px;
}
.confirm-box.show{display:flex;}
.confirm-box .panel{background:var(--bg-elev); border-radius:var(--radius-lg); padding:22px; max-width:320px; width:100%; text-align:center;}
.confirm-box .panel p{font-size:14px; color:var(--text-dim); margin:8px 0 18px; line-height:1.5;}
.confirm-box .panel h3{font-family:'Fraunces',serif; font-size:18px; margin:0;}
.confirm-box .actions{display:flex; gap:10px;}
.confirm-box .actions button{flex:1; padding:12px; border-radius:12px; font-weight:700; font-size:13.5px;}
.confirm-box .actions .cancel{background:var(--bg-card); color:var(--text-dim);}
.confirm-box .actions .ok{background:var(--danger); color:#fff;}
</style>
</head>
<body>

<div id="splash">
  <div class="mark"><span class="coin"></span>Cofre</div>
  <small>conectando...</small>
</div>

<div id="app">
  <header class="topbar">
    <div class="brand"><span class="coin"></span><h1>Cofre</h1></div>
    <button class="icon-btn" onclick="openSettings()">
