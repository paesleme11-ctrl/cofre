   Substitua firebaseConfig pelas credenciais do SEU projeto Firebase.
===================================================================== */
const firebaseConfig = {
  apiKey: "AIzaSyA5Vl2Hnv_uYEj_KkhFsI6GVwQBRRxvY30",
  authDomain: "financas-pessoais-ec8c5.firebaseapp.com",
  projectId: "financas-pessoais-ec8c5",
  storageBucket: "financas-pessoais-ec8c5.firebasestorage.app",
  messagingSenderId: "301380558959",
  appId: "1:301380558959:web:38b22134d1c5d47253ed9a"
};
firebase.initializeApp(firebaseConfig);
const auth = firebase.auth();
const db = firebase.firestore();

let uid = null;
let unsubscribers = [];

/* ---------- estado em memória ---------- */
const state = {
  transacoes: [],
  contas: [],
  metas: [],
  categorias: [],
  carteiras: [],
  hideBalance: false,
  currentMonth: new Date(),
  extratoFilter: { tipo:'todos', categoria:null },
  editing: { tx:null, bill:null, goal:null, aporteGoalId:null },
  manage: { mode:null, emoji:'🏷️', color:'#e3b13e' }
};

const DEFAULT_CATEGORIES = [
  {nome:'Alimentação', emoji:'🍔', cor:'#df7849'},
  {nome:'Transporte', emoji:'🚗', cor:'#5b9bd5'},
  {nome:'Moradia', emoji:'🏠', cor:'#8bbf6f'},
  {nome:'Lazer', emoji:'🎮', cor:'#c77dff'},
  {nome:'Saúde', emoji:'💊', cor:'#e2584f'},
  {nome:'Educação', emoji:'📚', cor:'#4fb0c6'},
  {nome:'Compras', emoji:'🛍️', cor:'#e3b13e'},
  {nome:'Assinaturas', emoji:'📱', cor:'#9b8cd8'},
  {nome:'Salário', emoji:'💼', cor:'#8bbf6f'},
  {nome:'Investimentos', emoji:'📈', cor:'#5fae8f'},
  {nome:'Outros', emoji:'📦', cor:'#a99d87'}
];
const DEFAULT_WALLETS = [
  {nome:'Carteira', emoji:'💵', cor:'#e3b13e', saldoInicial:0},
  {nome:'Conta corrente', emoji:'🏦', cor:'#5b9bd5', saldoInicial:0}
];
const EMOJI_OPTIONS = ['🍔','🚗','🏠','🎮','💊','📚','🛍️','📱','💼','📈','📦','🍕','☕','✈️','🐶','🎁','⚡','💡','📺','👕','🏋️','🎵','🍺','💳','🏦','💵','💰','🧾','🔧','🚙'];
const COLOR_OPTIONS = ['#e3b13e','#df7849','#8bbf6f','#5b9bd5','#c77dff','#e2584f','#4fb0c6','#9b8cd8','#5fae8f','#d4a574'];

/* =====================================================================
   AUTH + BOOTSTRAP
===================================================================== */
auth.onAuthStateChanged(user=>{
  if(user){
    uid = user.uid;
    bootstrapData();
  } else {
    auth.signInAnonymously().catch(err=>{
      console.error(err);
      document.querySelector('#splash small').textContent = 'Erro ao conectar — verifique o firebaseConfig';
    });
  }
});

function userDoc(path){ return db.collection('users').doc(uid).collection(path); }

async function bootstrapData(){
  // seed categorias/carteiras padrão se ainda não existem
  const catSnap = await userDoc('categorias').limit(1).get();
  if(catSnap.empty){
    const batch = db.batch();
    DEFAULT_CATEGORIES.forEach(c=>{
      const ref = userDoc('categorias').doc();
      batch.set(ref, c);
    });
    await batch.commit();
  }
  const walSnap = await userDoc('carteiras').limit(1).get();
  if(walSnap.empty){
    const batch = db.batch();
    DEFAULT_WALLETS.forEach(w=>{
      const ref = userDoc('carteiras').doc();
      batch.set(ref, w);
    });
    await batch.commit();
  }

  let loaded = 0;
  const checkAllLoaded = ()=>{
    loaded++;
    if(loaded>=5){
      document.getElementById('splash').style.display='none';
      document.getElementById('app').style.display='block';
      renderAll();
    }
  };

  listen('transacoes', checkAllLoaded);
  listen('contas', checkAllLoaded);
  listen('metas', checkAllLoaded);
  listen('categorias', checkAllLoaded);
  listen('carteiras', checkAllLoaded);
}

function listen(coll, onFirst){
  let first = true;
  const unsub = userDoc(coll).onSnapshot(snap=>{
    state[coll] = snap.docs.map(d=>({id:d.id, ...d.data()}));
    if(first){ first=false; onFirst(); }
    else { processRecurringBills(); renderAll(); }
  });
  unsubscribers.push(unsub);
}

/* =====================================================================
   HELPERS
===================================================================== */
function brl(v){
  v = Number(v)||0;
  return v.toLocaleString('pt-BR', {style:'currency', currency:'BRL'});
}
function parseMoneyInput(str){
  if(!str) return 0;
  str = str.toString().replace(/[^\d,.-]/g,'').replace(/\.(?=\d{3})/g,'').replace(',', '.');
  return parseFloat(str)||0;
}
function formatMoneyTyping(input){
  let v = input.value.replace(/\D/g,'');
  if(!v) { input.value=''; return; }
  v = (parseInt(v,10)/100).toFixed(2);
  input.value = v.replace('.', ',').replace(/\B(?=(\d{3})+(?!\d)\.?)/g,'');
  // adiciona separador de milhar
  let [intPart, decPart] = input.value.split(',');
  intPart = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  input.value = intPart + ',' + decPart;
}
['txAmount','billAmount','goalValue','goalCurrent','aporteAmount'].forEach(id=>{
  document.addEventListener('input', e=>{ if(e.target.id===id) formatMoneyTyping(e.target); });
});

function monthKey(date){ return date.getFullYear()+'-'+String(date.getMonth()+1).padStart(2,'0'); }
function isSameMonth(dateStr, date){ return dateStr && dateStr.slice(0,7) === monthKey(date); }
function fmtMonthLabel(date){
  return date.toLocaleDateString('pt-BR', {month:'long', year:'numeric'});
}
function todayISO(){ return new Date().toISOString().slice(0,10); }
function daysBetween(a,b){ return Math.round((new Date(b)-new Date(a))/86400000); }
function catById(id){ return state.categorias.find(c=>c.id===id); }
function walById(id){ return state.carteiras.find(w=>w.id===id); }
function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(()=>t.classList.remove('show'), 2200);
}

/* =====================================================================
   NAVEGAÇÃO
===================================================================== */
function goTo(view){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('view-'+view).classList.add('active');
  document.querySelectorAll('.navbtn').forEach(b=>b.classList.toggle('active', b.dataset.v===view));
  if(view==='extrato') renderExtrato();
  if(view==='contas') renderContas();
  if(view==='metas') renderMetas();
  window.scrollTo(0,0);
}
function openSheet(id){ document.getElementById(id).classList.add('show'); }
function closeSheet(id){ document.getElementById(id).classList.remove('show'); }
function toggleSwitch(id){ document.getElementById(id).classList.toggle('on'); }

/* =====================================================================
   RENDER PRINCIPAL
===================================================================== */
function renderAll(){
  renderDashboard();
  const active = document.querySelector('.view.active').id;
  if(active==='view-extrato') renderExtrato();
  if(active==='view-contas') renderContas();
  if(active==='view-metas') renderMetas();
}

/* ---------- DASHBOARD ---------- */
let categoryChartInstance=null, trendChartInstance=null;

function computeBalance(walletId){
  const wal = walById(walletId);
  let saldo = wal ? Number(wal.saldoInicial)||0 : 0;
  state.transacoes.forEach(t=>{
    if(t.carteira!==walletId) return;
    saldo += t.tipo==='receita' ? Number(t.valor) : -Number(t.valor);
  });
  return saldo;
}
function totalBalance(){
  return state.carteiras.reduce((sum,w)=>sum+computeBalance(w.id),0);
}
function monthTotals(date){
  let income=0, expense=0;
  state.transacoes.forEach(t=>{
    if(!isSameMonth(t.data, date)) return;
    if(t.tipo==='receita') income += Number(t.valor); else expense += Number(t.valor);
  });
  return {income, expense};
}
function categorySpending(date){
  const map = {};
  state.transacoes.forEach(t=>{
    if(t.tipo!=='despesa' || !isSameMonth(t.data, date)) return;
    map[t.categoria] = (map[t.categoria]||0) + Number(t.valor);
  });
  return map;
}

function toggleHideBalance(){
  state.hideBalance = !state.hideBalance;
  renderDashboard();
}

function renderDashboard(){
  const bal = totalBalance();
  const balEl = document.getElementById('dashBalance');
  balEl.textContent = state.hideBalance ? '••••••' : brl(bal);
  balEl.classList.toggle('hidden-val', false);

  const {income, expense} = monthTotals(new Date());
  document.getElementById('dashIncome').textContent = brl(income);
  document.getElementById('dashExpense').textContent = brl(expense);

  // wallets
  const ws = document.getElementById('walletsScroll');
  ws.innerHTML = state.carteiras.map(w=>`
    <div class="wallet-card">
      <div class="name">${w.emoji||'💳'} ${w.nome}</div>
      <div class="val num">${brl(computeBalance(w.id))}</div>
    </div>
  `).join('') + `<div class="wallet-card add" onclick="openManage('wallets')">+ <span style="font-size:11px;margin-left:4px;">nova</span></div>`;

  // donut chart
  const spend = categorySpending(new Date());
  const labels=[], data=[], colors=[];
  Object.entries(spend).sort((a,b)=>b[1]-a[1]).forEach(([catId,val])=>{
    const c = catById(catId);
    labels.push(c?c.nome:'Outros');
    data.push(val);
    colors.push(c?c.cor:'#a99d87');
  });
  const ctx = document.getElementById('categoryChart').getContext('2d');
  if(categoryChartInstance) categoryChartInstance.destroy();
  if(data.length===0){
    document.getElementById('categoryLegend').innerHTML = '<div class="empty-state" style="padding:18px;">Sem gastos registrados neste mês ainda 🌱</div>';
  } else {
    categoryChartInstance = new Chart(ctx, {
      type:'doughnut',
      data:{ labels, datasets:[{data, backgroundColor:colors, borderWidth:0}] },
      options:{ cutout:'68%', plugins:{legend:{display:false}, tooltip:{callbacks:{label:c=>` ${c.label}: ${brl(c.raw)}`}}} }
    });
    document.getElementById('categoryLegend').innerHTML = labels.map((l,i)=>`
      <div class="legend-item"><span class="sw" style="background:${colors[i]}"></span>${l} · ${brl(data[i])}</div>
    `).join('');
  }

  // trend chart - últimos 6 meses
  const months = [];
  for(let i=5;i>=0;i--){
    const d = new Date(); d.setMonth(d.getMonth()-i);
    months.push(d);
  }
  const incomeData = months.map(d=>monthTotals(d).income);
  const expenseData = months.map(d=>monthTotals(d).expense);
  const mlabels = months.map(d=>d.toLocaleDateString('pt-BR',{month:'short'}).replace('.',''));
  const tctx = document.getElementById('trendChart').getContext('2d');
  if(trendChartInstance) trendChartInstance.destroy();
  trendChartInstance = new Chart(tctx, {
    type:'bar',
    data:{ labels:mlabels, datasets:[
      {label:'Entradas', data:incomeData, backgroundColor:'#8bbf6f', borderRadius:5, maxBarThickness:16},
      {label:'Saídas', data:expenseData, backgroundColor:'#df7849', borderRadius:5, maxBarThickness:16}
    ]},
    options:{
      plugins:{legend:{display:false}},
      scales:{
        x:{grid:{display:false}, ticks:{color:'#a99d87', font:{size:11}}},
        y:{grid:{color:'rgba(255,255,255,.05)'}, ticks:{color:'#a99d87', font:{size:10}, callback:v=>'R$'+v}}
      }
    }
  });

  renderDashBills();
  renderDashGoals();
}

function billStatus(bill){
  if(bill.paga) return {label:'Paga', cls:'ok'};
  const days = daysBetween(todayISO(), bill.vencimento);
  if(days<0) return {label:'Atrasada', cls:'late'};
  if(days===0) return {label:'Vence hoje', cls:'late'};
  if(days<=7) return {label:`Vence em ${days}d`, cls:'soon'};
  return {label:new Date(bill.vencimento+'T00:00').toLocaleDateString('pt-BR',{day:'2-digit',month:'short'}), cls:'ok'};
}

function renderDashBills(){
