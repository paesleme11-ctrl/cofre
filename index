function goalProgress(g){
  if(g.tipo==='economia'){
    const {income, expense} = monthTotals(new Date());
    const net = income-expense;
    return {pct: Math.max(0, Math.min(100, (net/g.valorMeta)*100)), cur: net, over:false};
  }
  if(g.tipo==='limite'){
    const spend = categorySpending(new Date())[g.categoria]||0;
    return {pct: Math.min(100,(spend/g.valorMeta)*100), cur: spend, over: spend>g.valorMeta};
  }
  return {pct: Math.min(100,((g.valorAtual||0)/g.valorMeta)*100), cur: g.valorAtual||0, over:false};
}

function renderDashGoals(){
  const el = document.getElementById('dashGoalsCard');
  if(state.metas.length===0){
    el.innerHTML = '<div class="empty-state"><span class="em">🎯</span>Crie sua primeira meta</div>';
    return;
  }
  el.innerHTML = state.metas.slice(0,3).map(g=>{
    const p = goalProgress(g);
    const color = g.tipo==='limite' ? (p.over?'var(--danger)':'var(--income)') : 'var(--accent)';
    return `<div class="goal-mini">
      <div class="top"><span class="nm">${g.nome}</span><span class="pc">${Math.round(p.pct)}%</span></div>
      <div class="progress-track"><div class="progress-fill" style="width:${Math.min(100,p.pct)}%; background:${color}"></div></div>
    </div>`;
  }).join('');
}

