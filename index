  const emojiPool = mode==='wallets' ? ['💵','🏦','💳','👛','💰','🪙','📱','🏧'] : EMOJI_OPTIONS;
  document.getElementById('manageEmojiGrid').innerHTML = emojiPool.map(e=>
    `<div class="emoji-opt ${e===state.manage.emoji?'sel':''}" onclick="pickManageEmoji(this,'${e}')">${e}</div>`
  ).join('');
  document.getElementById('manageColorGrid').innerHTML = COLOR_OPTIONS.map(c=>
    `<div class="color-dot ${c===state.manage.color?'sel':''}" style="background:${c}" onclick="pickManageColor(this,'${c}')"></div>`
  ).join('');
  closeSheet('overlayManage');
  openSheet('overlayManageAdd');
}
function pickManageEmoji(el, e){
  state.manage.emoji = e;
  el.parentElement.querySelectorAll('.emoji-opt').forEach(x=>x.classList.remove('sel'));
  el.classList.add('sel');
}
function pickManageColor(el, c){
  state.manage.color = c;
  el.parentElement.querySelectorAll('.color-dot').forEach(x=>x.classList.remove('sel'));
  el.classList.add('sel');
}
async function saveManageAdd(){
  const mode = state.manage.mode;
  const name = document.getElementById('manageAddName').value.trim();
  if(!name){ toast('Dê um nome'); return; }
  const payload = { nome:name, emoji:state.manage.emoji, cor:state.manage.color };
  if(mode==='wallets') payload.saldoInicial = parseMoneyInput(document.getElementById('manageAddBalance').value);
  try{
    await userDoc(mode==='wallets'?'carteiras':'categorias').add(payload);
    toast('Adicionado');
    closeSheet('overlayManageAdd');
    openManage(mode);
  }catch(e){ console.error(e); toast('Erro ao salvar'); }
}

/* =====================================================================
   SETTINGS / TEMA
===================================================================== */
function openSettings(){ openSheet('overlaySettings'); }
function toggleTheme(){
  const html = document.documentElement;
  const isDark = html.getAttribute('data-theme')==='dark';
  html.setAttribute('data-theme', isDark ? 'light' : 'dark');
  document.getElementById('themeIcon').textContent = isDark ? '☀️' : '🌙';
  localStorage.setItem && null; // não usar localStorage em ambientes restritos
  if(categoryChartInstance || trendChartInstance) renderDashboard();
}

/* =====================================================================
   EXCLUSÃO COM CONFIRMAÇÃO
===================================================================== */
let pendingDelete = null;
function askDelete(kind){
  pendingDelete = kind;
  document.getElementById('confirmText').textContent =
    kind==='tx' ? 'Esse lançamento será excluído permanentemente.' :
    kind==='bill' ? 'Essa conta e seu histórico de lembrete serão excluídos.' :
    'Essa meta será excluída permanentemente.';
  document.getElementById('confirmBox').classList.add('show');
}
function closeConfirm(){ document.getElementById('confirmBox').classList.remove('show'); pendingDelete=null; }
async function confirmDelete(){
  try{
    if(pendingDelete==='tx' && state.editing.tx){
      await userDoc('transacoes').doc(state.editing.tx).delete();
      closeSheet('overlayTx');
    } else if(pendingDelete==='bill' && state.editing.bill){
      await userDoc('contas').doc(state.editing.bill).delete();
      closeSheet('overlayBill');
    } else if(pendingDelete==='goal' && state.editing.goal){
      await userDoc('metas').doc(state.editing.goal).delete();
      closeSheet('overlayGoal');
    }
    toast('Excluído');
  }catch(e){ console.error(e); toast('Erro ao excluir'); }
  closeConfirm();
}

/* fecha sheet ao clicar fora */
document.querySelectorAll('.overlay').forEach(ov=>{
  ov.addEventListener('click', e=>{ if(e.target===ov) ov.classList.remove('show'); });
});
</script>
