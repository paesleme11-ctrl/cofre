function renderExtrato(){
  document.getElementById('extratoMonthLbl').textContent = fmtMonthLabel(state.currentMonth);

  const filters = [
    {k:'todos', l:'Todos'}, {k:'receita', l:'Receitas'}, {k:'despesa', l:'Despesas'}
  ];
  document.getElementById('extratoFilters').innerHTML = filters.map(f=>`
    <button class="chip ${state.extratoFilter.tipo===f.k?'active':''}" onclick="setExtratoFilter('${f.k}')">${f.l}</button>
  `).join('');

  let list = state.transacoes.filter(t=>isSameMonth(t.data, state.currentMonth));
  if(state.extratoFilter.tipo!=='todos') list = list.filter(t=>t.tipo===state.extratoFilter.tipo);
  list.sort((a,b)=>b.data.localeCompare(a.data) || (b.createdAt||0)-(a.createdAt||0));

  const container = document.getElementById('extratoList');
  if(list.length===0){
    container.innerHTML = '<div class="empty-state"><span class="em">📭</span>Nenhum lançamento neste mês</div>';
    return;
  }
  const groups = {};
  list.forEach(t=>{ (groups[t.data] = groups[t.data]||[]).push(t); });

  container.innerHTML = Object.entries(groups).map(([date, items])=>{
    const dLabel = new Date(date+'T00:00').toLocaleDateString('pt-BR',{weekday:'short', day:'2-digit', month:'short'});
    const rows = items.map(t=>{
      const cat = catById(t.categoria);
